{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./.types/common",
    "tsBuildInfoFile": "./.types/common.tsbuildinfo",
    "rootDir": "src/common"
  },
  "include": [
    "src/common/**/*.ts"
  ]
}