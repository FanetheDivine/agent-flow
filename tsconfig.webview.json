{
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "tsBuildInfoFile": "./.types/webview.tsbuildinfo",
    "rootDir": "src",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/webview/**/*.ts",
    "src/webview/**/*.tsx"
  ],
  "references": [
    {
      "path": "./tsconfig.common.json"
    }
  ]
}