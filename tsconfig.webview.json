{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "sourceMap": true,
    "noEmit": true,
    "rootDir": "src",
    "strict": true,
    "moduleResolution": "bundler",
    "composite": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/webview/**/*.ts", "src/webview/**/*.tsx", "src/common/**/*.ts"]
}
