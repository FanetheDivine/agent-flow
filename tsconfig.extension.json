{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "tsBuildInfoFile": "./.types/extension.tsbuildinfo",
    "rootDir": "src",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/extension/**/*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.common.json"
    }
  ]
}